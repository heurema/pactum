# Pactum workspace — the durable run record (contracts, decisions, the ledger,
# gate verdicts, review findings, memory) is versioned; regenerable artifacts and
# raw transcripts are excluded by .heurema/pactum/.gitignore.

# Local build output (make build / go build -o bin/pactum).
/bin/

# Default go build ./cmd/... output binaries at the repo root.
# Root-anchored so cmd/pactum and cmd/heurema-hygiene source dirs stay tracked.
/pactum
/pactum.exe
/heurema-hygiene
/heurema-hygiene.exe
